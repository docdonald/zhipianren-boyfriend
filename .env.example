# =============================================================
# 纸片人男友 · 环境变量模板（.env.example）
# =============================================================
# ⚠️  变量分两类（绝不能搞混）：
#   【SERVER-ONLY】   任何不带 NEXT_PUBLIC_ 前缀的变量
#                     只在 Node 服务端可见，永不进浏览器
#                     ⚠️  绝不能用 NEXT_PUBLIC_ 命名密钥！
#   【CLIENT-OK】     带 NEXT_PUBLIC_ 前缀的变量
#                     会被 Next.js 打包进浏览器，必须是公开值
#                     （如：站点 URL、Analytics ID）
#
#  6 个 lib 模块已用 `import "server-only"` 守护
#  如果哪天误在前端 import 它们，编译/构建会立即报错
# =============================================================


# ===== LLM（对话 + 跃迁判定）=====
# 火山方舟 · Doubao-Seed-Character（角色扮演专用模型）
# 申请：https://www.volcengine.com/product/ark  → API 密钥管理
# 端点：https://ark.cn-beijing.volces.com/api/v3（OpenAI 兼容）
# 模型：doubao-seed-character
# 价格：0.8 元/百万 token（输入 ≤32k）| 2.0 元/百万 token（输出 ≤32k）
# 说明：与 SEEDREAM（图像生成）共享同一个 API Key
ARK_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ARK_LLM_MODEL=doubao-seed-character-251128
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# ===== Auth (NextAuth v5) =====
# `openssl rand -base64 32`
AUTH_SECRET=replace-with-openssl-rand-base64-32
# 公网 URL（部署后改成 vercel url）
NEXTAUTH_URL=http://localhost:3000

# ===== Database (libSQL / Turso) =====
# 本地开发：使用 file:./data/pb.db
DATABASE_URL=file:./data/pb.db
# 部署：使用 Turso，命令 `turso db show <db> --url`
# DATABASE_URL=libsql://xxx.turso.io
# TURSO_TOKEN=xxxxxxxx

# ===== Email (Resend) =====
# 申请：https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx
RESEND_FROM=Paper Boyfriend <noreply@paperboyfriend.com>
# 公开站点 URL（用于邮件内链、退订链接）
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ===== 火山引擎 TTS =====
# 申请：https://www.volcengine.com/product/text-to-speech
VOLCENGINE_APP_ID=xxxxxxxx
VOLCENGINE_ACCESS_KEY=xxxxxxxx
VOLCENGINE_SECRET_KEY=xxxxxxxx
# 4 角色声线 ID（开通后在控制台查询）
TTS_VOICE_LIN=zh_male_shuangkuai
TTS_VOICE_ZHOU=zh_male_chunhou
TTS_VOICE_JIANG=zh_male_ruxin
TTS_VOICE_XIA=zh_male_yangguang

# ===== seedream-5 立绘 =====
# 字节跳动豆包 - Seedream
SEEDREAM_API_KEY=xxxxxxxx
SEEDREAM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
SEEDREAM_MODEL=doubao-seedream-5-260128

# ===== seedream-4 文生图（通用）=====
# 与 LLM 共用同一个 ARK_API_KEY，只需配置模型名
SEEDREAM_IMAGE_MODEL=doubao-seedream-4-0-250828

# ===== Cron 安全 =====
# 随机字符串，Vercel Cron 调用时验证
CRON_SECRET=replace-with-random-string
